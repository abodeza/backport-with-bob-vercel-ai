# exa-search-demo credentials — read as environment variables by server.mjs.
# Copy this file to `.env` and fill in your key, then run `pnpm start`.
# Do NOT commit your real `.env`.

# Vercel AI Gateway key. Used outside Vercel deployments; inside a Vercel
# deployment auth falls back to VERCEL_OIDC_TOKEN automatically.
AI_GATEWAY_API_KEY=
